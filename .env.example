# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database URLs (defaults work for local PostgreSQL with user 'postgres')
DATABASE_URL=postgres://postgres:postgres@localhost:5432/staffclock
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/staffclock_test

# Production examples:
# DATABASE_URL=postgres://user:password@host:5432/staffclock?sslmode=require

# JWT (REQUIRED in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=7d

# SMTP Email (REQUIRED in production)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@yourdomain.com

# App Settings
APP_NAME=StaffClock
APP_URL=http://localhost:3000

# Verification
VERIFICATION_TOKEN_EXPIRY=24

# CORS
CORS_ORIGIN=*

# Bcrypt
BCRYPT_ROUNDS=12
